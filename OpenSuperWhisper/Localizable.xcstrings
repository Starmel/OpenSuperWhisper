    "Are you sure you want to delete all recordings? This action cannot be undone.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer tous les enregistrements ? Cette action est irréversible."
