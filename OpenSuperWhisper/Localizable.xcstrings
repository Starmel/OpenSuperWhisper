        }
      }
    },
    "Automatically remove recordings older than the chosen age": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer automatiquement les enregistrements plus anciens que l'âge choisi"
