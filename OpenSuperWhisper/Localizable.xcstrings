          }
        }
      }
    },
    "When disabled, audio recordings and transcriptions are not saved to disk. Only the current transcription is kept in memory for pasting.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est désactivée, les enregistrements audio et les transcriptions ne sont pas sauvegardés sur le disque. Seule la transcription en cours est conservée en mémoire pour le collage."
          }
        }
      }
    },
    "Where the recording indicator appears.": {
      "localizations": {
