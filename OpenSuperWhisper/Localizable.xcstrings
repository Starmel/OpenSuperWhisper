        }
      }
    },
    "Available in your command (also piped as JSON on stdin):": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponible dans votre commande (aussi transmis en JSON sur stdin) :"
