        }
      }
    },
    "Automatically pause media playback when recording starts": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettre automatiquement la lecture des médias en pause au démarrage de l'enregistrement"
